  $defaultSession     = new Zend_Session_Namespace();
  if(!isset($defaultSession->logoutoken)) {
  	$defaultSession->logoutoken = Sirah_User_Helper::getToken(15).time();
  }
  $logoutoken         = $defaultSession->logoutoken;

  $linkStatLocalites  = $view->url(array("controller" => "statistiques", "action" => "localites"), "frontend");
