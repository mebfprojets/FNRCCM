  $linkRequests       = $view->url(array("controller" => "requetes","action" => "list", "module" => "public"), "default");
  $linkSettings       = $view->url(array("controller" => "account", "action" => "settings", "module" => "public"), "default");
  $forgotPasswordLink = $this->url(array("controller" => "recoverpwd", "action" => "init" , "module" => "public")  , "default");
  
  $jq                 = $view->jQuery();
  $onLoad             = "
                          jQuery('.recoverMyPwd').click(function( event ){event.preventDefault(); document.location.href = '".$forgotPasswordLink."'; });
                          jQuery('.createAccount').click(function(event ){event.preventDefault(); document.location.href = '".$linkCreateAccount."';  });
                          jQuery('.login').click(function( event ){ 
                                 event.preventDefault();
                                 var loginForm  = jQuery('#useraccountLoginForm') ;
                                 var  username  = jQuery.trim(jQuery('#username').val());
                                 var  credential= jQuery.trim(jQuery('#password').val());      
                                 if( SIRAH.util.isEmpty(username)){
                                    jQuery('#username').addClass('input-error');
                                    SIRAH.error.raise('useraccountLoginForm','Entrez un identifiant valide');
                                    return;
                                 }      
                                 if(SIRAH.util.isEmpty(credential) || (parseInt(credential.length) < 4)){
                                    jQuery('#password').addClass('input-error');
                                    SIRAH.error.raise('useraccountLoginForm','Entrez un mot de passe valide');
                                    return;
                                 }
                                  loginForm.submit();});
                           ";
  
  $jq->addOnLoad( $onLoad );
?>
