   $output      = " <table id=\"paiementsList\" class=\"table table-striped table-responsive paiementsList\">
                       <thead>
                              <tr>
                                     <th width=\"width:2%\"> *         </th>
                                     <th width=\"width:25%\"> Dates    </th>
