   	   	        $numero       = $paiement["numero"];
   	   	        $datePaiement = $paiement["date_paiement"];
   	   	        $montant      = number_format( $paiement["montant"], 2, ","," ");
   	   	        $solde        = number_format( $paiement["reste"]  , 2, ","," ");
   	   	        $paiementTotal+= $paiement["montant"];
   	   	        $lastSolde    = $paiement["reste"];
   	   	        $rowBg        = $this->cycle(array("#F0F0F0","#F5F5F5"))->next();
   	   	        
   	   	        $output      .="  <tr id=\"paiementId-".$paiementid ."\" style=\"background-color:".$rowBg."\"> ";
   	   	              $output.="     <td> <span title=\"Supprimer ce paiement\" href=\"#\" id=\"delPaiementId-".$paiementid."\" class=\"glyph-icon icon-remove pull-left delPaiement \"></span> </td>";
   	   	              $output.="     <td> ".$datePaiement." </td>";
   	   	              $output.="     <td> ".$numero."       </td>";
   	   	              $output.="     <td> ".$montant."      </td>";
   	   	              $output.="     <td> ".$solde."    </td>";
   	   	        $output      .=" </tr>";
   	   }
   	   $rowBg               = $this->cycle(array("#F0F0F0","#F5F5F5"))->next();
   	   $paiementTotalFormat = number_format( $paiementTotal, 2 , ",", " " );
   	   $totalSolde          = floatval( $valCommande - $paiementTotal );
   	   $totalSoldeFormat    = number_format($lastSolde, 2 , ",", " " );
   	   $output      .="<tr id=\"paiementId-Total\" style=\"background-color:".$rowBg."\"> 
   	                        <td colspan=\"3\"> TOTAL </td>
   	                        <td> ".$paiementTotalFormat." </td>
   	                        <td> ".$totalSoldeFormat."    </td>
   	                   </tr>";
   } else {
   	   $output     .=" <tr> <td style=\"text-align:center;\" colspan=\"6\"> Aucun paiement n'a été enregistré pour cette commande </td> </tr>";
   }
   $output.= " </tbody></table>";   
    
   echo  $output ;
        
