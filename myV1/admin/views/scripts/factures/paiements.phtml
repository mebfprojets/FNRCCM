                                     <th width=\"width:28%\"> Montants </th>
                                     <th width=\"width:25%\"> Soldes   </th>
                              </tr>
                       </thead>";
   
   if( count(   $paiements ) ) {
   	            $paiementTotal= 0;
   	            $soldeTotal   = 0;
   	            $lastSolde    = 0;
   	            $valCommande  = isset($paiements[0]["totalAPayer"] ) ? $paiements[0]["totalAPayer"] : $commande->valeur;
