		   publishedState             = 0;
	    }
		var paginationData            = {};
		paginationData.page           = pageNum;
		paginationData.maxitems       = parseInt(formSelector.find('#maxitems').val());	
	
		paginationData.libelle        = jQuery.trim(jQuery('#articlesListSearchForm').find('#libelle').val());
		paginationData.catid          = parseInt(formSelector.find('#catid').val());		
		paginationData.published      = publishedState;
		paginationData.page           = pageNum;
		
		var maincontent               = jQuery('#maincontent');			
		SIRAH.loading.on(maincontent, 'Chargement des données...' );
