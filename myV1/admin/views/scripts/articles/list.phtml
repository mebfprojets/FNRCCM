jQuery('input:checkbox').uniform({checkboxClass:'checkbox-primary'});
var getCheckedArticlesId = function() {
	var checkedItems = jQuery('#articlesListTable').find('input[type=\'checkbox\'][name!=\'checkAll\']:checked');
	var checkedIds   = []; 
	if( checkedItems) {
		checkedItems.each(function() {
			var articleid = parseInt(jQuery(this).attr('id').replace('articleids',''));
			checkedIds.push(articleid);
		});
	}
	return checkedIds;
};
jQuery('#articlesListTable').find('input[type=\'checkbox\']').bind('checkAll', function(event){enableButtons(['deleteButton','exportButton','copyButton','editButton']);});
jQuery('#articlesListTable').find('input[type=\'checkbox\']').bind('unCheckAll',function(event){disableButtons(['deleteButton','exportButton','copyButton','editButton']);});
jQuery('#articlesListTable').find('input[type=\'checkbox\']').bind('clickRow',function(event){enableButtons(['deleteButton','exportButton','copyButton','editButton']);});
jQuery('#articlesListTable').find('input[type=\'checkbox\']').bind('unClickRow',function(event){
	checkedItems = jQuery('#articlesListTable').find('input[type=\'checkbox\'][name!=\'checkall\']:checked');
	if( checkedItems.length <= 0 ) {
