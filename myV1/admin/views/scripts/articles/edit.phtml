	   jQuery('#categorie-validation-message').html('');
	   SIRAH.error.raise('categorie-validation-message', 'Sélectionnez une catégorie');
	   return;
	} else {
	   jQuery('#categorie-validation-message').html('');
	}	
	formSelector.find('#content').val(contenu); 
	formSelector.find('#introtext').val(introtext);  
	formSelector.submit();
}); ";
