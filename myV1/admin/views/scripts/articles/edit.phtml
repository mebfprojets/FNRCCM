	var introtext    = tinymce.get('introtext').getContent();

	if(SIRAH.util.isEmpty(title)) {
	   jQuery('#title-validation-message').html('');
	   SIRAH.error.raise('title-validation-message', 'Saisissez le titre de l\'article');
	   return;
	} else {
	   jQuery('#title-validation-message').html('');
