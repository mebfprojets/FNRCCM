var keyPressedReqhasSent = false;
var makeRequestTimer     = defaultXHR  = null;
var charsPressed         = 0;
jQuery('#searchQ').on('keypress paste', function( event ){
	charsPressed++;	
	if(event.type=='keyup' && event.keyCode!=8) return;
	if( makeRequestTimer) clearTimeout(makeRequestTimer);
	if( defaultXHR ) defaultXHR.abort();	   
	makeRequestTimer = setTimeout(function() {		      
		var formSelector         = jQuery('#globalFormSearch');
		var advancedFormSelector = jQuery('#accountsListSearchForm');
		var maincontent	         = jQuery('#maincontent');

		var defaultData          = {};
		defaultData.name         = searchKey = defaultData.searchQ = formSelector.find('#searchQ').val(); 
		defaultData.roleid       = parseInt(formSelector.find('#roleid').val());
		defaultData.localiteid   = parseInt(formSelector.find('#localiteid').val()); 			
		defaultData.page         = 1;
		defaultData.showsearch   = 0;
		defaultData.maxitems     = advancedFormSelector.find('#maxitems').val();
		if( searchKey.length >= 5 ) {
			SIRAH.loading.on(jQuery('#globalfilterRow'), 'Patientez...');
			SIRAH.request.post('globalFormSearch', '".$linkSearch."',{data: defaultData,dataType:'html',async:true,
								 beforeSend:function(jqXHR) {defaultXHR = jqXHR;keyPressedReqhasSent=true;},
								 error     :function(data){maincontent.html(data);basicLoadPage();SIRAH.loading.off(false);jQuery('.dropdown-toggle').dropdown();charsPressed=0;},
								 success   :function(data){maincontent.html(data);basicLoadPage();SIRAH.loading.off(false);jQuery('.dropdown-toggle').dropdown();charsPressed=0;},
								 update    :function(data){maincontent.html(data);basicLoadPage();SIRAH.loading.off(false);jQuery('.dropdown-toggle').dropdown();charsPressed=0;}		
			});
		}		      
	},5000);
});			
