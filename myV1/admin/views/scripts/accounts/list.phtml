jQuery('.sirahPaginationBtn').click(function(event){
	event.preventDefault();
	if( jQuery(this).is('.active') || jQuery(this).is('.disabled') || jQuery(this).is('.currentBtn')) {
		return false;
	}
	var formSelector       = jQuery('#accountsListSearchForm');
	var pageNum            = parseInt(jQuery(this).attr('id').replace('paginationBtnPage-' , ''));
	var pageMaxitems       = formSelector.find('#maxitems').val();
	if( jQuery(this).is('.nextPage')) {
		var currentBtnNum   = parseInt(jQuery('.currentBtn').first().attr('id').replace('paginationBtnPage-' , ''));
		pageNum             = parseInt( currentBtnNum +1);
	}
	if( jQuery(this).is('.prevPage')) {
		var currentBtnNum     = parseInt(jQuery('.currentBtn').first().attr('id').replace('paginationBtnPage-' , ''));
		pageNum               = parseInt( currentBtnNum - 1);
	}
	var paginationData        = {};
	paginationData.maxitems   = pageMaxitems;
	paginationData.page       = pageNum;
	paginationData.phone      = jQuery('#phone').val();
	paginationData.roleid     = parseInt(formSelector.find('#roleid').val());
	paginationData.localiteid = parseInt(formSelector.find('#localiteid').val());
	paginationData.username   = formSelector.find('#username').val();
	paginationData.lastname   = formSelector.find('#lastname').val();
	paginationData.firstname  = formSelector.find('#firstname').val();
	paginationData.email      = formSelector.find('#email').val();
	var maincontent	          = jQuery('#maincontent');	
	SIRAH.loading.on( maincontent , 'Chargement des données...' );
	SIRAH.request.post('accountsListSearchForm' , '".$linkSearch."' , 
					   {
						  dataType   : 'html' ,
						  data       : paginationData,
						  beforeSend : function() { },
						  error      : function(data){maincontent.html(data);basicLoadPage();SIRAH.loading.off(false);},
						  success    : function(data){maincontent.html(data);basicLoadPage();SIRAH.loading.off(false);},
						  update     : function(data){maincontent.html(data);basicLoadPage();SIRAH.loading.off(false);}		
					  });
	SIRAH.loading.off(false);		
});
