		          SIRAH.request.post('globalFormSearch', '".$linkSearch."',{data: defaultData,dataType:'html',async:true,
		                             beforeSend:function(jqXHR) {defaultXHR = jqXHR;keyPressedReqhasSent=true;},
		                             error     :function(data){maincontent.html(data);SIRAH.loading.off(false);jQuery('.dropdown-toggle').dropdown();charsPressed=0;},
	                                 success   :function(data){maincontent.html(data);SIRAH.loading.off(false);jQuery('.dropdown-toggle').dropdown();charsPressed=0;},
		                             update    :function(data){maincontent.html(data);SIRAH.loading.off(false);jQuery('.dropdown-toggle').dropdown();charsPressed=0;}		
		                     });
			  }		      
		},1000);
});
var getCheckedRoleIds= function() {
		var checkedItems = jQuery('#rolesListTable').find('input[type=\'checkbox\'][name!=\'checkall\']:checked');
        var checkedIds   = []; 
		if(checkedItems) {
		   checkedItems.each(function(){var roleid = parseInt(jQuery(this).attr('id').replace('roleids-',''));checkedIds.push(roleid);});
		}
		return checkedIds;
};
