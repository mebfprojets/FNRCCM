                          $output   = "";
                          if( count( $roles )) {
                          	foreach( $roles as $roleid => $rolename ) {
                          		     $accessLevel = Sirah_User_Acl_Table::getAccesslevel($roleid);
                          		     $parents     = Sirah_User_Acl_Table::getRoleParents($roleid);                        		     
                          		     $linkInfos   = $this->url(array("module"=>"admin","controller"=>"useroles","action"=>"infos","roleid"=>$roleid));
                          		                               		     
                          		     $output .="<tr class=\"".$bgClass."\" id=\"rowRole-".$roleid."\">";
                          		             $output .= "<td id=\"checkboxCell-".$roleid."\"><input type=\"checkbox\" name=\"roleids[]\" id=\"roleids-".$roleid."\" class=\"roleids\" /> </td>";
                          		             $output .= "<td id=\"roleName-".$roleid."\">  <a href=\"".$linkInfos."\"> ".$rolename." </a> </td>";
                          		             if(empty($parents )){
                          		             	$output .= "<td id=\"parents-".$roleid."\"><a href=\"".$linkInfos."\"> Aucun </a> </td>";
                          		             } else {
                          		             	$output .= "<td id=\"parents-".$roleid."\"><a href=\"".$linkInfos."\"> ".implode(', ', $parents)." </a> </td>";
                          		             }
                          		             if(!empty($accessLevel) && isset( $priorities[$accessLevel[0]] )) {
                          		             	$output .= "<td id=\"priorities-".$roleid."\"> <a href=\"".$linkInfos."\"> ".$priorities[$accessLevel[0]]." </a> </td>";
                          		             }  else {
                          		             	$output .= "<td id=\"priorities-".$roleid."\"> <a href=\"".$linkInfos."\"> ".$priorities[5]." </a> </td>";
                          		             }
                          		     $output .="<input type=\"hidden\" id=\"rolename-".$roleid."\" name=\"rolename-".$roleid."\" value=\"".$rolename."\"  />"  ;
                          		     $output .="</tr>";
                          	}                          	
                          } else {
