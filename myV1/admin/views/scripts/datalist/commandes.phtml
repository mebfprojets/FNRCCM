            $model   = $this->model;
             //On crée et affiche le tableau
             $table  = $this->table(array("id" => "commandesListTable","class"  => array("table table-hover table-bordered table-stripped sirah-ui-table scrollable")));
             $header = $table->row();             
             $header->add("<input type=\"checkbox\" name=\"checkall\" id=\"checkAll\" class=\"checkAll\" />" , array("width" => "1%"))
                    ->add("Références"      , array("width" => "9%"))
                    ->add("Prestataires"    , array("width" => "20%"))
                    ->add("Produits"        , array("width" => "25%"))
                    ->add("Valeurs"         , array("width" => "10%"))
                    ->add("Dates"           , array("width" => "10%"))
                    ->add("Délais livraison", array("width" => "15%"))
                    ->add("Statuts"         , array("width" => "10%"));         
             $table->setHeader($header);             
             if(count( $commandes ) ){
             	foreach( $commandes as $commande ) {             		
             	   $commandeid    = intval($commande['id']);
             	   $reference     = $commande["reference"] ;
             	   $prestataire   = $commande["prestataire"];
             	   $dateCommande  = $commande["dateCommande"];
             	   $dateLivraison = $commande["dateLivraison"];
             	   $valeur        = number_format( $commande["valeur"] , 0 , "," , " ");
             	   $lignes        = $model->getLignes( $commandeid );
             	   $statut        = ( isset( $statuts[$commande["statut"]] ) ) ? $statuts[$commande["statut"]] : "Invalide";
             	   $listeProduit  = "";
             	   if( count(   $lignes ) ) {
             	   	   foreach( $lignes as $ligne ) {
             	   	   	$listeProduit.= $ligne["quantite"]." ".$ligne["produit"] .", ";
             	   	   }
             	   } else {
             	   	    $listeProduit.= "Aucun produit associé";
             	   }            	   
             	   $commandeRow   = $table->row(array("id"  => "commandeRowId-" . $commandeid ));
             	   $commandeRow->add("<input type=\"checkbox\" name=\"commandeids[]\" id=\"commandeids" . $commandeid ."\" />" , array("id" => "checkboxCell-" . $commandeid ))
             		           ->add("<a href=\"#commandeid-".$commandeid."\" class=\"selectClick\" >" . $reference    . "</a>" , array("id" => "numcommande-" . $commandeid ))
             	               ->add("<a href=\"#commandeid-".$commandeid."\" class=\"selectClick\" >" . $prestataire  . "</a>" , array("id" => "prestataireId-"   . $commandeid ))
             	               ->add("<a href=\"#commandeid-".$commandeid."\" class=\"selectClick\" >" . $listeProduit . "</a>" , array("id" => "produitId-"       . $commandeid ))
             		           ->add("<a href=\"#commandeid-".$commandeid."\" class=\"selectClick\" >" . $valeur       . "</a>" , array("id" => "valeurId-"        . $commandeid ))
             		           ->add("<a href=\"#commandeid-".$commandeid."\" class=\"selectClick\" >" . $dateCommande . "</a>" , array("id" => "dateId-"          . $commandeid ))
             		           ->add("<a href=\"#commandeid-".$commandeid."\" class=\"selectClick\" >" . $dateLivraison. "</a>" , array("id" => "dateLivraisonId-" . $commandeid ))
             	               ->add("<a href=\"#commandeid-".$commandeid."\" class=\"selectClick\" >" . $statut       . "</a>" );
             	   $table->add($commandeRow);
             	   
             	   echo "<input type=\"hidden\" name=\"reference-".$commandeid."\" id=\"reference-".$commandeid."\" value=\"".$reference."\" />";
             	}
             }  else {
             	$unfoundRow  = $table->row(array("style"  => 'text-align:center;'));
             	$unfoundRow->add(" Aucun résultat n'a été retrouvé , réessayez avec d'autres critères de recherche", array("colspan"  => 7));
             	$table->add($unfoundRow);
             } 
