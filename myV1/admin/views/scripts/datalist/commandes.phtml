		    pageNum             = parseInt( currentBtnNum - 1);
		}
		var paginationData           = {};
		paginationData.maxitems      = pageMaxitems;
		paginationData.page          = pageNum;
		paginationData.produitid     = parseInt(jQuery('#produitid').val());
		paginationData.prestataireid = parseInt(jQuery('#prestataireid').val());
