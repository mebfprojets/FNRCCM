jQuery('#searchfrom').change(function(event){
	event.preventDefault();
	var repository = jQuery('#globalFormSearch').find('#searchfrom').val().toUpperCase();
	var minLength  = 3;
	switch(repository) {
		case 'ERCCM':
		case 'FNRCCM':
		default:
			minLength = 3;
			break;
		case 'APISIGU':
		case 'SIGUE':
		case 'SIGU':
			minLength = 5;
			break;
		case 'apiods':
		case 'apidgi':
			minLength = 5;
			break;
	}
	//jQuery('#searchQ').typeahead('setVal','yourValue');
	jQuery('#searchQ').attr('data-min-length' ,minLength);
});
