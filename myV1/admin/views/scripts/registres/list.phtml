jQuery('.sirahPaginationBtn').click(function(event){
	event.preventDefault();
	if(jQuery(this).is('.active') || jQuery(this).is('.disabled') || jQuery(this).is('.currentBtn')) {
		 return false;
	}
	var simpleSearchSelector= jQuery('#globalFormSearch');
	var formSelector        = jQuery('.advancedSearchForm').eq(0) ;
	var pageNum             = parseInt(jQuery(this).attr('id').replace('paginationBtnPage-' , ''));
	var pageMaxitems        = formSelector.find('#maxitems').val();
	var searchQ             = simpleSearchSelector.find('#searchQ').val();
	var searchQType         = parseInt(simpleSearchSelector.find('#type').val());
	if(jQuery(this).is('.nextPage')) {
		  var currentBtnNum = parseInt(jQuery('.currentBtn').first().attr('id').replace('paginationBtnPage-' , ''));
		  pageNum           = parseInt( currentBtnNum +1);
	}
	if( jQuery(this).is('.prevPage')) {
		var currentBtnNum    = parseInt(jQuery('.currentBtn').first().attr('id').replace('paginationBtnPage-' , ''));
		pageNum              = parseInt( currentBtnNum - 1);
	}
	var paginationData                     = {};
	var selectedDomaineIds                 = getSelectedDomaines(formSelector);
    paginationData.domaineids              = selectedDomaineIds;	
    var selectedLocaliteIds                = getSelectedLocalites(formSelector);
    paginationData.localiteids             = selectedLocaliteIds;
	paginationData.page                    = pageNum;
	paginationData.maxitems                = parseInt(formSelector.find('#maxitems').val());
	if(!SIRAH.util.isEmpty(searchQ)) {
		paginationData.searchQ             = searchQ;
		paginationData.searchQType         = searchQType;
	} else {
		paginationData.numero              = jQuery.trim(formSelector.find('#numero').val());
		paginationData.libelle             = jQuery.trim(formSelector.find('#libelle').val());
		paginationData.name                = jQuery.trim(formSelector.find('#name').val());		
		paginationData.passport            = jQuery.trim(formSelector.find('#passport').val());
		paginationData.phone               = jQuery.trim(formSelector.find('#phone').val());
