		paginationData.numifu              = jQuery.trim(formSelector.find('#numifu').val());
		paginationData.numcnss             = jQuery.trim(formSelector.find('#numcnss').val());
		paginationData.creatorid           = parseInt(formSelector.find('#creatorid').val());
		paginationData.localiteid          = 0;
		paginationData.type                = parseInt(formSelector.find('#type').val());
		paginationData.annee               = parseInt(formSelector.find('#annee').val());
		paginationData.date_year           = parseInt(formSelector.find('#date_year').val());
