jQuery('input:checkbox').uniform({checkboxClass:'checkbox-primary'});
var getCheckedRequetesId = function() {
		var checkedItems  = jQuery('#requetesListTable').find('input[type=\'checkbox\'][name!=\'checkall\']:checked');
        var checkedIds    = []; 
		if(checkedItems) {
		   checkedItems.each(function() {
             	var requestid   = parseInt(jQuery(this).attr('id').replace('requestids',''));
             	checkedIds.push(requestid);
           });
		}
		return checkedIds;
  };
jQuery('#requetesListTable').find('input[type=\'checkbox\']').click(function(e){
		 var checkedItems  = jQuery('#requetesListTable').find('input[type=\'checkbox\'][name!=\'checkall\']:checked');
		 if(jQuery(this).attr('id') == 'checkAll') {
		    if(!jQuery(this).is(':checked')) {
		       checknone(jQuery('#requetesListTable'));
		       if(checkedItems) {
		           disableButtons(['processButton','deleteButton']);
		       }
		    } else {
		      checkall(jQuery('#requetesListTable'));
		      enableButtons(['processButton','deleteButton']);
		    }
		 } else {
		  if(jQuery(this).is(':checked')) {
		     enableButtons(['processButton','actionButton','exportButton','deleteButton']);
		  } else {
		      if( SIRAH.util.isEmpty(checkedItems)) {
		          disableButtons(['processButton','deleteButton']);
		       }
		  }
		}
   });
