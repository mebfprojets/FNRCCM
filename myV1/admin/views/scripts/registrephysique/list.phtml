					   var localizedButton  = jQuery.fn.dialog2.localization.localizedButton;
		               if( isDisabled || SIRAH.util.isEmpty( checkedRegistres )) {
		                   SIRAH.dialog.alert('Vous devrez selectionner au moins une ligne avant d\'effectuer cette opération','Selectionnez une ligne');
		                   return;
                       }
		               var dialogIndexation = jQuery('<div> Voulez-vous vraiment re-indexer les registres selectionnés ? Les documents rattachés à ces registres vont être remplacés </div>').attr('id','dialogIndexation');             		             		   
					   dialogIndexation.dialog2({title :'Attention, confirmer cette action !!',autoOpen:false,removeOnClose:true,closeOnEscape:false,closeOnOverlayClick: true,showCloseHandle:true,initialLoadText: 'Chargement...' });        		
             		   dialogIndexation.dialog2('addButton','<i class=\'glyph-icon icon-check\'> </i> Oui',{primary:true,click : 
             		                            function(){
												jQuery('.modal-footer:first').find('button.btn').remove();
												jQuery('#dialogIndexation').dialog2('addButton','Annuler',{click:function(){jQuery('#dialogIndexation').dialog2('close'); }});
												jQuery('.modal-header:first').find('h3').first().html('Re-Indexation en cours...');
												var progressBarContainer = jQuery('<div/>').addClass('progressbar').addClass('progress-striped').attr('data-value','0').attr('id','progressbar');	
												var progressBarValue     = jQuery('<div/>').addClass('progressbar-value').addClass('bg-red').addClass('tooltip-button').attr('data-original-title','Initialisation...').attr('id','progressBarValue')
												                           .append(jQuery('<div/>').addClass('progress-label').html('0%').attr('id', 'progressLabel'))
																		   .append(jQuery('<div/>').addClass('progress-overlay').attr('id','progressBarOverlay'));	
												progressBarContainer.append(progressBarValue);
												jQuery('#dialogIndexation').html(progressBarContainer);
												var progressBarTxt       = jQuery('<div/>').addClass('row').css('color','black').css('font-weight','bold').attr('id','progressBarTxt');
												jQuery('#dialogIndexation').append(progressBarTxt);
												var nbre                 = 0;
												var totalSuccess         = 0;
												var totalRegistres       = checkedRegistres.length;
												jQuery.each(checkedRegistres, function(key,registreid) {			    
													    var numeroRegistre  = jQuery('#numero-'+registreid).val();														
														setTimeout(function(){
															var xhr = jQuery.ajax({url:'".$linkIndexation."',async:true,dataType:'json',type:'GET',data:{'registreid':registreid}});
															xhr.done(function( data ){
																nbre++;
																if( data.error !== undefined ) {
																	SIRAH.error.raise(jQuery('#dialogIndexation'),data.error, 'error');																						
																} else if( data.success !== undefined ) {
																	totalSuccess++;
																}
																var percent    = parseInt(nbre*(100/totalRegistres));
																var percentTxt = percent+'%';
														        progressBarContainer.attr('data-value', percent );
																progressBarValue.css('width', percentTxt);
														        progressBarValue.attr('data-original-title','Indexation du registre n° '+numeroRegistre+'...');
														        jQuery('#progressLabel').html(percentTxt);
																progressBarTxt.html('(Copie du registre n° '+numeroRegistre+' en cours...)');																												
																
																if( nbre == totalRegistres ) {
																	progressBarValue.removeClass('bg-red').addClass('bg-green');
															        SIRAH.error.raise(jQuery('#dialogIndexation'),'L\'opération d\'indexation des documents s\'est effectuée avec succès, au total,'+totalSuccess+' ont été indexés', 'success');
															        setTimeout(function(){jQuery('#dialogIndexation').dialog2('close');return false;},4500);											        
														        }
															});	
															jQuery('.modal-footer:first').find('button.btn').first().click(function(event){ event.preventDefault();xhr.abort();});															
														}, 500);														
												});														   
                                                           }}); 
             		      dialogIndexation.dialog2('addButton','<i class=\'glyph-icon icon-ban\'></i>Annuler', {primary: false,click : function(){jQuery(this).dialog2('close');}});              		
             		      dialogIndexation.dialog2('open');");				
