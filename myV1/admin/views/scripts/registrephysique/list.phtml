jQuery('.sirahPaginationBtn').click(function(event){
		event.preventDefault();
		if(jQuery(this).is('.active') || jQuery(this).is('.disabled') || jQuery(this).is('.currentBtn')) {
		     return false;
		}
		var formSelector        = jQuery('.advancedSearchForm').eq(0) ;
		var simpleSearchSelector= jQuery('#globalFormSearch');
		var pageNum             = parseInt(jQuery(this).attr('id').replace('paginationBtnPage-' , ''));
		var pageMaxitems        = formSelector.find('#maxitems').val();
		var searchQ             = simpleSearchSelector.find('#searchQ').val();
		var searchQType         = parseInt(simpleSearchSelector.find('#type').val());
	    if(jQuery(this).is('.nextPage')) {
		      var currentBtnNum = parseInt(jQuery('.currentBtn').first().attr('id').replace('paginationBtnPage-' , ''));
		      pageNum           = parseInt( currentBtnNum +1);
		}
		if( jQuery(this).is('.prevPage')) {
		    var currentBtnNum    = parseInt(jQuery('.currentBtn').first().attr('id').replace('paginationBtnPage-' , ''));
		    pageNum              = parseInt( currentBtnNum - 1);
		}
		var paginationData                     = {};
		paginationData.page                    = pageNum;
		paginationData.maxitems                = parseInt(formSelector.find('#maxitems').val());
		if(!SIRAH.util.isEmpty(searchQ)) {
			paginationData.searchQ             = searchQ;
			paginationData.searchQType         = searchQType;
		} else {
			paginationData.numero              = jQuery.trim(formSelector.find('#numero').val());
			paginationData.numcnss             = jQuery.trim(formSelector.find('#numcnss').val());
			paginationData.numifu              = jQuery.trim(formSelector.find('#numifu').val());
			paginationData.libelle             = jQuery.trim(formSelector.find('#libelle').val());
			paginationData.name                = jQuery.trim(formSelector.find('#name').val());	
			paginationData.passport            = jQuery.trim(formSelector.find('#passport').val());
			paginationData.keywords            = jQuery.trim(formSelector.find('#keywords').val());	
			paginationData.sexe                = jQuery.trim(formSelector.find('#sexeVal').val());		
			paginationData.creatorid           = parseInt(formSelector.find('#creatorid').val());
			paginationData.localiteid          = parseInt(formSelector.find('#localiteid').val());
			paginationData.domaineid           = parseInt(formSelector.find('#domaineid').val());
			paginationData.country             = parseInt(formSelector.find('#country').val());
			paginationData.statut              = parseInt(formSelector.find('#statut').val());
			paginationData.annee               = parseInt(formSelector.find('#annee').val());
			paginationData.date_year           = parseInt(formSelector.find('#date_year').val());
			paginationData.date_month          = parseInt(formSelector.find('#date_month').val());
			paginationData.date_day            = parseInt(formSelector.find('#date_day').val());
			paginationData.periode_start_year  = parseInt(formSelector.find('#periode_start_year').val());
			paginationData.periode_end_year    = parseInt(formSelector.find('#periode_end_year').val());
			paginationData.periode_start_month = parseInt(formSelector.find('#periode_start_month').val());
			paginationData.periode_end_month   = parseInt(formSelector.find('#periode_end_month').val());
			paginationData.periode_start_day   = parseInt(formSelector.find('#periode_start_day').val());
			paginationData.periode_end_day     = parseInt(formSelector.find('#periode_end_day').val());
		}			       					 	
		var maincontent                    = jQuery('#maincontent');			
		SIRAH.loading.on( maincontent , 'Patientez...' );
		jQuery('#registresListWrapper').loadingOn();
		SIRAH.request.post(formSelector, '".$linkSearch."' , 
		                   {  dataType   :'html' ,
