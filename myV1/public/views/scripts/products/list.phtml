<?php
$jq     = $this->jQuery();  
$onLoad = " jQuery('.equal-height-panels .panel').matchHeight();
            jQuery('.selectProduct').click(function( event ){event.preventDefault();
				var productid  = parseInt(jQuery(this).attr('href').replace('#selectProductId-', ''));
				document.location.href='".$linkSelectProduct."/productid/'+productid;
			});";
$jq->addOnLoad($onLoad);
