       			       $photoGardePath   =  $activite["photogarde"];
       			       if( file_exists( $photoGardePath ) ) {
       				       $photoGardePathname = str_replace( APPLICATION_PATH , ROOT_PATH . DS ."myV1", $photoGardePath );
       				       $photoGarde         = str_replace( DS , "/", $photoGardePathname );
       				       //$photoGarde         = str_replace( "original", "mini", $photoGarde );
       			       }
       		      }
       		      if( !empty( $photoGarde ) ) {
       			       $output         .="<li class=\"list-group-item\" id=\"activityId-".$activityId."\" >";
