       			                                      <p  class=\"list-group-item-text\"> ".$introduction." <a title=\"En savoir plus\" href=\"".$linkInfos."\">[...]</a> </p>";
       			      if( count( $beneficiaires ) ){
       				           $output .=" <p  class=\"list-group-item-text\">  <span class=\"text-muted small\"> ".$beneficiairesOutput." </span> </p> ";
       			      }
       			      if( intval( $activite["datedebut"] ) && intval( $activite["datefin"])) {
