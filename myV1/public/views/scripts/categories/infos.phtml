       		     $beneficiaires    = $modelActivite->beneficiaires( $activityid );
       
       		     $periode          = sprintf("%s - %s", date("d/m/Y", $activite["datedebut"] ), date("d/m/Y", $activite["datefin"] ) );
       		     $photoGarde       = "";
       		     
