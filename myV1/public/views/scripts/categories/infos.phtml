?>
<div class="panel panel-default">
       <div class="panel-heading"> <?php echo $categorie->libelle;      ?></div>
       <div class="panel-body"   > <?php echo $categorie->description;  ?></div>
       <?php 
       
       $modelActivite   = new Model_Activite();
       $output          = "  <ul class=\"list-group \"> ";
