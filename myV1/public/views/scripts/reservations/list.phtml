var getCheckedDemandesId = function() {
		var checkedItems = jQuery('#demandesListTable').find('input[type=\'checkbox\'][name!=\'checkAll\']:checked');
        var checkedIds   = []; 
		if( checkedItems) {
		    checkedItems.each(function() {
             	var demandeid   = parseInt(jQuery(this).attr('id').replace('demandeids',''));
             	checkedIds.push(demandeid);
            });
		}
		return checkedIds;
};
