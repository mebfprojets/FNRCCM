jQuery('.sirahPaginationBtn').click(function(event){
		event.preventDefault();
		if(jQuery(this).is('.active') || jQuery(this).is('.disabled') || jQuery(this).is('.currentBtn')) {
		     return false;
		}
		var formSelector        = jQuery('#demandesListSearchForm') ;
		var pageNum             = parseInt(jQuery(this).attr('id').replace('paginationBtnPage-' , ''));
		var pageMaxitems        = formSelector.find('#maxitems').val();
		var disponible          = 0;
		var expired             = 0;
		if( jQuery('input[name=\'disponible\']:checked').attr('id')!==undefined) {
			disponible          = jQuery('input[name=\'disponible\']:checked').val();   
		}
        if( jQuery('input[name=\'expired\']:checked').attr('id')!==undefined) {
			expired             = jQuery('input[name=\'expired\']:checked').val();   
		}
	    if(jQuery(this).is('.nextPage')) {
		      var currentBtnNum = parseInt(jQuery('.currentBtn').first().attr('id').replace('paginationBtnPage-' , ''));
		      pageNum           = parseInt( currentBtnNum +1);
		}
		if( jQuery(this).is('.prevPage')) {
		    var currentBtnNum              = parseInt(jQuery('.currentBtn').first().attr('id').replace('paginationBtnPage-' , ''));
		    pageNum                        = parseInt( currentBtnNum - 1);
		}
		var paginationData                 = {};
		paginationData.page                = pageNum;
		paginationData.maxitems            = parseInt(formSelector.find('#maxitems').val());	
	
	    paginationData.demandeurname       = formSelector.find('#demandeurname').val();
		paginationData.promoteurname       = formSelector.find('#promoteurname').val();
		paginationData.libelle             = jQuery.trim(formSelector.find('#libelle').val());
		paginationData.numero              = jQuery.trim(formSelector.find('#numero').val());
		paginationData.typeid              = parseInt(formSelector.find('#typeid').val());
		paginationData.demandeurid         = parseInt(formSelector.find('#demandeurid').val());
		paginationData.promoteurid         = parseInt(formSelector.find('#promoteurid').val());
 
		paginationData.statutid            = parseInt(formSelector.find('#statutid').val());
		paginationData.disponible          = disponible;
		paginationData.expired             = expired;
		
		paginationData.periode_start_year  = parseInt(formSelector.find('#periode_start_year').val());
		paginationData.periode_end_year    = parseInt(formSelector.find('#periode_end_year').val());
		paginationData.periode_start_month = parseInt(formSelector.find('#periode_start_month').val());
		paginationData.periode_end_month   = parseInt(formSelector.find('#periode_end_month').val());
		paginationData.periode_start_day   = parseInt(formSelector.find('#periode_start_day').val());
		paginationData.periode_end_day     = parseInt(formSelector.find('#periode_end_day').val());
		paginationData.maxitems            = pageMaxitems;
		paginationData.page                = pageNum;
		paginationData.reset               = 1;
		
		var maincontent                    = jQuery('#maincontent');			
		SIRAH.loading.on(maincontent, 'Chargement des données...' );
		SIRAH.request.post(formSelector, '".$linkSearch."' , 
		                   {  dataType   :'html' ,
		                      async      : true,
		                      data       : paginationData,
		                      beforeSend : function() { },
		                      error      : function(data){maincontent.html(data);SIRAH.loading.off(false);},
	                          success    : function(data){maincontent.html(data);SIRAH.loading.off(false);},
		                      update     : function(data){maincontent.html(data);SIRAH.loading.off(false);}		
		                  });		
});	
