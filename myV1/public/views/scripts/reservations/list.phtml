jQuery('.resetSearch,.resetSearchBtn,.resetForm,.resetSearchBtn').click(function(event){
	    event.preventDefault();
		if( jQuery(this).hasClass('disabled') ) {
		    return;
		}
		var formSelector   = jQuery('#globalFormSearch') ;
		var searchData     = {};	
		searchData.libelle = searchData.objet = searchData.name = searchData.searchQ = '';
        searchData.reset   = 1;		
        var maincontent	   = jQuery('#maincontent');				
		SIRAH.loading.on(maincontent, 'Chargement des données...' );
		SIRAH.request.post(formSelector, '".$linkSearch."' , 
		                   {  dataType   :'html' ,
		                      async      : true,
		                      data       : searchData,
		                      beforeSend : function() { },
		                      error      : function(data){maincontent.html(data);SIRAH.loading.off(false);},
	                          success    : function(data){maincontent.html(data);SIRAH.loading.off(false);},
		                      update     : function(data){maincontent.html(data);SIRAH.loading.off(false);}		
		                  });				
});	
