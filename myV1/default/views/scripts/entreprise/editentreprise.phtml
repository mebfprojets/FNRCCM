      } else {
         jQuery('#libelle').removeClass('input-error');
         jQuery('#libelle-validation-message').html('');
      }
      if(SIRAH.util.isEmpty(telephone)){
        jQuery('#telephone').addClass('input-error');
        jQuery('#telephone-validation-message').html('');
         SIRAH.error.raise('telephone-validation-message','Entrez un numéro de téléphone valide');
         return;
      }  else {
