         jQuery('#telephone-validation-message').html('');
      }
   	  if(SIRAH.util.isEmpty(codepostal)){
        jQuery('#codepostal').addClass('input-error');
        jQuery('#codepostal-validation-message').html('');
         SIRAH.error.raise('codepostal-validation-message','Entrez un code postal valide');
         return;
      }  else {
         jQuery('#codepostal').removeClass('input-error');
         jQuery('#codepostal-validation-message').html('');
      }
   	 if(!SIRAH.validators.isEmailAddress(email)){
        jQuery('#email').addClass('input-error');
        jQuery('#email-validation-message').html('');
         SIRAH.error.raise('email-validation-message','Entrez une addresse email valide');
         return;
      }  else {
         jQuery('#email').removeClass('input-error');
         jQuery('#email-validation-message').html('');
      }                  
      jQuery('#telephone').val(telephone);
      jQuery('#libelle').val(libelle);
   	  jQuery('#email').val(email);
      formSelector.submit();  ");
