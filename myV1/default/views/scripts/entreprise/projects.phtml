<?php 
   $entreprise  = $this->entreprise;
   $projects    = $this->projects;
   $linkDelete  = $this->url(array("controller" => "projects", "action" => "delete", "entrepriseid" => $this->entrepriseid), "default") ;
   $linkCreate  = $this->url(array("controller" => "projects", "action" => "create", "entrepriseid" => $this->entrepriseid), "default") ;
   $output      = " <table id=\"projectsList\" class=\"table table-striped table-responsive projectsList\">
                       <thead>
                              <tr>
                                     <th width=\"width:2%\"> *         </th>
                                     <th width=\"width:50%\"> Périodes </th>
                                     <th width=\"width:48%\"> Intitulés</th>
                              </tr>
                       </thead>";
   
   if( count(   $projects ) ) {
   	   foreach( $projects as $project ) {
   	   	        $projectid      = $project["projectid"]; 
				$projectLib     = $project["libelle"];
								   
				$zendStartime   = ( $project["startime"]) ? new Zend_Date( $project["startime"] ,Zend_Date::TIMESTAMP ) :null;
             	$valStartime    = ( $zendStartime ) ? $zendStartime->toString("dd MMMM yyyy") : "";
								   
				$zendEndtime    = ( $project["endtime"]) ? new Zend_Date( $project["endtime"] ,Zend_Date::TIMESTAMP ) :null;
             	$valEndtime     = ( $zendEndtime ) ? $zendEndtime->toString("dd MMMM yyyy") : "";
				$projectPeriode = sprintf("%s - %s", $valStartime, $valEndtime );
								   								   
				$linkInfos      = $this->url(array("controller" => "project", "action" => "infos", "projectid" => $projectid) , "default");
				
				$rowBg          = $this->cycle(array("#F0F0F0","#F5F5F5"))->next();
   	   	        
   	   	        $output      .="  <tr id=\"projectId-".$projectid ."\" style=\"background-color:".$rowBg."\"> ";
   	   	              $output.="     <td> <span title=\"Supprimer ce projet\" href=\"#\" id=\"delProjectId-".$projectid."\" class=\"glyph-icon icon-remove pull-left delProject \"></span> </td>";
   	   	              $output.="     <td> <a title=\"Voir les informations de ce projet\" href=\"".$linkInfos ."\"> ".$projectPeriode." </a> </td>";
   	   	              $output.="     <td> <a title=\"Voir les informations de ce projet\" href=\"".$linkInfos ."\"> ".$projectLib    ."  </a> </td>";
   	   	        $output      .=" </tr>";
   	   }
   } else {
   	   $output     .=" <tr> <td style=\"text-align:center;\" colspan=\"6\"> Aucun projet n'a été enregistré pour votre entreprise </td> </tr>";
   }
   $output.= " </tbody></table>";   
    
   echo  $output ;
        
$jq      =  $this->jQuery();
