jQuery('.delProject').css('cursor','pointer');
jQuery('.delProject').click(function( event ){      
          var itemId           = parseInt(jQuery(this).attr('id').replace('delProjectId-',''));
          var dialogDeleteItem = jQuery('<div> Etes-vous sur de supprimer ce project ? </div>').attr('id','dialogDeleteItem');
          dialogDeleteItem.dialog2({title:'Confirmer l\'action',autoOpen:false,removeOnClose:true,closeOnEscape: false,closeOnOverlayClick:true,showCloseHandle:true,initialLoadText: 'Chargement...'});   
