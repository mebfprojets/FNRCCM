                      ->add("Désignations")
                      ->add("Hérite du/des role(s)")
                      ->add("Priorités");
            $table->setHeader($rowHeader);
            
            if(array_key_exists($this->roleid,$roles)) {
            	unset($roles[$this->roleid]);
            }
            
            $checkedRoles   = array_intersect_key( $roles, $parents);
            $uncheckedRoles = array_diff_key( $roles , $parents);
            
          if(!empty($checkedRoles)) {
         	 foreach($checkedRoles as $checkedRoleId => $checkedRoleName) {
         		$checkedRoleRow  = $table->row(array("id" => "rowRole-".$checkedRoleId));
